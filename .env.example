# ============================================
# FreeStyle - Environment Configuration
# ============================================

# --- Server ---
NODE_ENV=development
PORT=3001
CLIENT_URL=http://localhost:5173

# --- Travelpayouts API ---
TP_API_TOKEN=your_travelpayouts_api_token_here
TP_MARKER=your_partner_marker_id
TP_PROJECT_ID=your_project_id

# --- Travelpayouts API Base URLs ---
TP_API_BASE_URL=https://api.travelpayouts.com
TP_AFFILIATE_BASE_URL=https://tp.media

# --- Cache Configuration ---
CACHE_DEFAULT_TTL=900
CACHE_REFERENCE_TTL=86400

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# --- Locale ---
DEFAULT_LOCALE=ru
DEFAULT_CURRENCY=rub
